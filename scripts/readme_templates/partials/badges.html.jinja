<div align="center" style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin: 20px 0;">
  <!-- Language Bindings -->
{%- for badge_id, badge in badges.items() %}
{%- if badge_id not in ("ci", "license", "homebrew", "docs") %}
  <a href="{{ badge.link }}">
    <img src="{{ badge.url }}" alt="{{ badge_id | title }}">
  </a>
{%- endif %}
{%- endfor %}

  <!-- Project Info -->
  <a href="{{ badges.ci.link }}">
    <img src="{{ badges.ci.url }}" alt="CI">
  </a>
  <a href="{{ badges.license.link }}">
    <img src="{{ badges.license.url }}" alt="License">
  </a>
  <a href="{{ badges.homebrew.link }}">
    <img src="{{ badges.homebrew.url }}" alt="Homebrew">
  </a>
  <a href="{{ badges.docs.link }}">
    <img src="{{ badges.docs.url }}" alt="Docs">
  </a>
</div>
